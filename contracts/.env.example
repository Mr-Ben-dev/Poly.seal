# Polyseal Contracts Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# Polygon Mainnet RPC URL (Alchemy recommended)
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Your wallet private key (WITHOUT 0x prefix)
# WARNING: Never share this! Only used locally for deployment.
PRIVATE_KEY=your_private_key_here_without_0x_prefix

# Polygonscan API Key for contract verification
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# Optional: Gas reporter
REPORT_GAS=true
COINMARKETCAP_API_KEY=your_cmc_key_for_gas_in_usd
